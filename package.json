{
  "name": "still",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "prepare": "node node_modules/.bin/nx-cloud-setup-workspace 2>/dev/null || true",

    "dev:api": "pnpm nx serve api",
    "dev:web": "pnpm nx serve web",
    "dev:ai": "pnpm nx serve ai-service",
    "dev:mobile": "pnpm nx start mobile",
    "dev:desktop": "pnpm nx serve desktop",

    "build:api": "pnpm nx build api",
    "build:web": "pnpm nx build web",
    "build:all": "pnpm nx run-many -t build --projects=api,web --parallel=2",

    "test": "pnpm nx run-many -t test --parallel=4",
    "test:api": "pnpm nx test api",
    "test:web": "pnpm nx test web",
    "test:libs": "pnpm nx run-many -t test --projects=writing,library,intelligence,publishing,api-contracts --parallel=4",
    "test:affected": "pnpm nx affected -t test",

    "lint": "pnpm nx run-many -t lint --parallel=4",
    "lint:affected": "pnpm nx affected -t lint",

    "typecheck": "pnpm nx run-many -t typecheck --parallel=4",
    "typecheck:affected": "pnpm nx affected -t typecheck",

    "check": "pnpm nx run-many -t typecheck,lint,test --parallel=4",
    "check:affected": "pnpm nx affected -t typecheck,lint,test",

    "graph": "pnpm nx graph",
    "projects": "pnpm nx show projects",
    "format": "pnpm nx format:write"
  },
  "devDependencies": {
    "@babel/core": "^7.14.5",
    "@babel/preset-react": "^7.14.5",
    "@babel/runtime": "~7.26.0",
    "@eslint/js": "^9.8.0",
    "@expo/cli": "~0.21.8",
    "@nestjs/schematics": "^10.0.1",
    "@nestjs/testing": "^10.0.2",
    "@nx/eslint": "20.8.4",
    "@nx/eslint-plugin": "20.8.4",
    "@nx/expo": "20.8.4",
    "@nx/jest": "20.8.4",
    "@nx/js": "20.8.4",
    "@nx/nest": "20.8.4",
    "@nx/node": "20.8.4",
    "@nx/react": "20.8.4",
    "@nx/vite": "20.8.4",
    "@nx/web": "20.8.4",
    "@nx/webpack": "20.8.4",
    "@nx/workspace": "^20.0.0",
    "@swc-node/register": "~1.9.1",
    "@swc/cli": "~0.6.0",
    "@swc/core": "~1.5.7",
    "@swc/helpers": "~0.5.11",
    "@testing-library/dom": "10.4.0",
    "@testing-library/jest-native": "~5.4.3",
    "@testing-library/react": "16.1.0",
    "@testing-library/react-native": "~12.9.0",
    "@types/jest": "^29.5.12",
    "@types/node": "^22.0.0",
    "@types/react": "19.0.0",
    "@types/react-dom": "19.0.0",
    "@vitejs/plugin-react": "^4.2.0",
    "@vitest/coverage-v8": "^3.0.5",
    "@vitest/ui": "^3.0.0",
    "babel-preset-expo": "~12.0.1",
    "eslint": "^9.8.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-import": "2.31.0",
    "eslint-plugin-jsx-a11y": "6.10.1",
    "eslint-plugin-react": "7.35.0",
    "eslint-plugin-react-hooks": "5.0.0",
    "jest": "^29.7.0",
    "jest-environment-node": "^29.7.0",
    "jest-expo": "~52.0.2",
    "jiti": "2.4.2",
    "jsdom": "~22.1.0",
    "nx": "^20.0.0",
    "nx-cloud": "latest",
    "prettier": "^3.3.3",
    "react-test-renderer": "~18.3.1",
    "ts-jest": "^29.1.0",
    "ts-node": "10.9.1",
    "tslib": "^2.3.0",
    "typescript": "~5.5.2",
    "typescript-eslint": "^8.19.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0",
    "webpack-cli": "^5.1.4"
  },
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=20.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@parcel/watcher",
      "@swc/core",
      "esbuild",
      "nx"
    ]
  },
  "dependencies": {
    "@expo/metro-config": "~0.19.4",
    "@expo/metro-runtime": "~4.0.0",
    "@nestjs/common": "^10.0.2",
    "@nestjs/core": "^10.0.2",
    "@nestjs/platform-express": "^10.0.2",
    "expo": "~52.0.11",
    "expo-splash-screen": "~0.29.13",
    "expo-status-bar": "~2.0.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-native": "0.76.3",
    "react-native-svg": "~15.8.0",
    "react-native-svg-transformer": "~1.5.0",
    "react-native-web": "~0.19.13",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.0"
  }
}
